# Path to your cloud-synced data directory
# This is where all databases, memory files, and logs are stored
# Examples:
#   macOS:   ~/Library/CloudStorage/OneDrive-Personal/ai-assistant-data
#   Linux:   ~/OneDrive/ai-assistant-data
#   Windows: /c/Users/YourName/OneDrive/ai-assistant-data  (Git Bash style)
WORKSPACE_DATA_DIR=~/OneDrive/ai-assistant-data
